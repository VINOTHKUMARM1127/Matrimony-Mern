          "dark": {
            "colors": {
              "cropToolbarColor": "#E8631A",
              "cropToolbarIconColor": "#FFFFFF",
              "cropToolbarActionTextColor": "#FFFFFF",
              "cropToolbarBackButtonIconColor": "#FFFFFF",
              "cropScreenBackgroundColor": "#121212"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1a4e062a-8329-44f6-9160-4ea2303cebf4"
      }
    }
  }
}
