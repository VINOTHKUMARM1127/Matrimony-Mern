{
  "expo": {
    "name": "MATRIMONY",
    "slug": "MATRIMONY",
    "version": "1.0.0",
    "orientation": "portrait",
    "primaryColor": "#E8631A",
    "scheme": "lotmatch",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E8631A"
      },
      "package": "com.vinoth_kumarm_27.MATRIMONY"
    },
    "web": {},
    "plugins": [
      [
        "expo-image-picker",
        {
